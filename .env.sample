# Required — OpenRouter key (NOT Anthropic)
OPENROUTER_API_KEY=sk-or-YOUR_OPENROUTER_KEY

# Optional model (OpenRouter model id)
# OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Optional — when running without Slack CLI (python3 app.py)
# SLACK_APP_TOKEN=xapp-YOUR_APP_TOKEN
# SLACK_BOT_TOKEN=xoxb-YOUR_BOT_TOKEN

# Required for OAuth (app_oauth.py)
# SLACK_CLIENT_ID=YOUR_CLIENT_ID
# SLACK_CLIENT_SECRET=YOUR_CLIENT_SECRET
# SLACK_SIGNING_SECRET=YOUR_SIGNING_SECRET
# SLACK_REDIRECT_URI=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app/slack/oauth_redirect
